# Secrets — structurally un-committable. A secret should be physically unable to
# enter a commit regardless of who reviews (see the secrets-and-teardown skill).
# Force-allow only the non-secret templates back in.
.env
.env.*
!.env.example
*.tfvars
!*.tfvars.example
*.tfstate
*.tfstate.*
*.pem
*.key
*.p12
id_rsa
id_ed25519
credentials.json
service-account*.json

# OS / editor cruft
.DS_Store
Thumbs.db

# Dependencies / build output
node_modules/
