# DoD criteria for the weigh-before-stance extension (SPECS v4 DoD mapping)
ci_green      = required   # pre-commit run --all-files (== CI, CONTRIBUTING.md)
machine_acs   = required   # AC-2..AC-8 batch (SPECS v4)
acceptance_green = required # AC-9..18: recorded non-author verdicts, latest attempts, hash-bound
grooming      = required   # no placeholders in the six shipped files
lint          = n/a        # markdownlint runs inside ci_green
coverage      = n/a        # docs pack — no code coverage surface
telemetry     = n/a        # docs pack — no runtime
