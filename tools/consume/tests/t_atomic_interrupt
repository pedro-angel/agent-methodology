#!/bin/sh
# AC-3d: an interrupted bump (dies after materialize, before the symlink re-point)
# leaves the PRIOR pin resolving — no MISSING window.
# shellcheck source=./_lib.sh disable=SC1091
. "$(dirname "$0")/_lib.sh"
B="$TOOLS/bump.sh"
# shellcheck disable=SC2046
set -- $(mk_bump_pack)
p=$1; v1=$2; v2=$3
sym="$p/cur"; mat="$p/mat"

BUMP_ASSUME_YES=1 sh "$B" "$p" "$v1" "$v1" "$mat" "$sym" >/dev/null 2>&1
# mutant: die right before the symlink re-point (simulates an interrupt there).
awk '{ if (/^ln -sfn/) print "die \"simulated interrupt before publish\""; print }' "$B" >"$p/mut.sh"
sh -n "$p/mut.sh" || { scrub "$p"; fail "mutant not valid shell"; }
cp "$TOOLS/materialize.sh" "$p/materialize.sh"   # the mutant resolves materialize.sh beside itself
rc=$(BUMP_ASSUME_YES=1 run_rc sh "$p/mut.sh" "$p" "$v2" "$v2" "$mat" "$sym")
still=$(basename "$(readlink "$sym")")
scrub "$p"

[ "$rc" -ne 0 ]      || fail "interrupted bump did not fail (rc=$rc)"
[ "$still" = "$v1" ] || fail "interrupted bump left the symlink at $still (want prior v1) — a MISSING window"
pass "t_atomic_interrupt (interrupt before publish → prior pin $still intact)"
