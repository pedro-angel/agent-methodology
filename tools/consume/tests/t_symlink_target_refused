#!/bin/sh
# Security hygiene (Copilot review, PR #25): provisioning REFUSES to write through a
# pre-existing symlink at an install-owned target (croot/bootcheck.sh, cfg/settings.json)
# — it fails loud and does NOT clobber the file the symlink points at. The guard runs
# before any write. (Broader untrusted-env tamper-resistance is the consumer's structural
# boundary per SPECS; this is the local write-through guard.)
# shellcheck source=./_lib.sh disable=SC1091
. "$(dirname "$0")/_lib.sh"
IC="$TOOLS/install-consumer.sh"
p=$(mk_pack alpha) || fail "mk_pack"
sha=$(git -C "$p" rev-parse HEAD)

for tgt in croot cfg; do
  croot="$p/cr_$tgt"; cfg="$p/cf_$tgt"; mkdir -p "$croot" "$cfg/skills"
  sentinel="$p/SECRET_$tgt"; printf important >"$sentinel"
  case $tgt in
    croot) ln -s "$sentinel" "$croot/bootcheck.sh" ;;
    cfg)   ln -s "$sentinel" "$cfg/settings.json" ;;
  esac
  rc=$(BUMP_ASSUME_YES=1 run_rc sh "$IC" "$p" "$sha" "$croot" "$cfg")
  [ "$rc" -ne 0 ] || { scrub "$p"; fail "$tgt: provisioning did NOT refuse a symlinked target (rc=$rc)"; }
  [ "$(cat "$sentinel")" = important ] || { scrub "$p"; fail "$tgt: the symlink target was CLOBBERED"; }
done
scrub "$p"
pass "t_symlink_target_refused (both targets refused; pointed-to file intact)"
